
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserPlan {
  FREE
  STARTER
  PRO
}

enum WorkSessionStatus {
  RUNNING
  PAUSED
  ENDED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
}

enum InvoiceTemplateType {
  CLASSIC
  MODERN
  MINIMAL
  CUSTOM
}

enum InvoiceSource {
  GENERATED
  UPLOADED
}

model User {
  id                 String    @id @default(cuid())
  name               String?
  email              String    @unique
  emailVerified      DateTime?
  image              String?
  stripeCustomerId   String?
  isTwoFactorEnabled Boolean   @default(false)
  role               String    @default("user")
  currency           String    @default("CHF")
  hourlyRate         Float     @default(0)
  createdAt          DateTime  @default(now())
  plan               UserPlan   @default(FREE)
  updatedAt          DateTime  @updatedAt
  accounts           Account[]
  sessions           Session[]
  workSessions       WorkSession[]
  clients            Client[]
  projects           Project[]
  serviceTypes       ServiceType[]
  businessProfile    BusinessProfile?
  invoices           Invoice[]
  invoiceTemplates   InvoiceTemplate[]
  expenses           Expense[]
  bankAccounts       BankAccount[]
}

model Account {
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model WorkSession {
  id        String             @id @default(cuid())
  userId    String
  status    WorkSessionStatus  @default(RUNNING)
  startedAt DateTime
  endedAt   DateTime?
  timezone  String?
  note      String?
  clientId  String?
  projectId String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  client    Client?            @relation(fields: [clientId], references: [id], onDelete: SetNull)
  project   Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  breaks    WorkBreak[]

  @@index([userId, startedAt])
  @@index([status])
  @@index([clientId])
  @@index([projectId])
}

model ServiceType {
  id        String    @id @default(cuid())
  userId    String
  name      String
  color     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects  Project[]

  @@unique([userId, name])
  @@index([userId])
}

model Client {
  id         String    @id @default(cuid())
  userId     String
  name       String
  email      String?
  address    String?
  postalCode String?
  city       String?
  country    String?
  color      String?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects     Project[]
  workSessions WorkSession[]
  invoices     Invoice[]

  @@unique([userId, name])
  @@index([userId])
}

model Project {
  id            String       @id @default(cuid())
  userId        String
  name          String
  description   String?
  clientId      String?
  serviceTypeId String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  client       Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  serviceType  ServiceType?  @relation(fields: [serviceTypeId], references: [id], onDelete: SetNull)
  workSessions WorkSession[]
  invoices     Invoice[]

  @@unique([userId, name])
  @@index([userId])
  @@index([clientId])
  @@index([serviceTypeId])
}

model WorkBreak {
  id         String      @id @default(cuid())
  sessionId  String
  startedAt  DateTime
  endedAt    DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  session    WorkSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, startedAt])
}

model BusinessProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  companyName  String?
  address      String?
  city         String?
  postalCode   String?
  country      String?
  siret        String?
  email        String?
  phone        String?
  logoUrl      String?
  vatMention   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invoice {
  id               String              @id @default(cuid())
  userId           String
  number           Int
  displayNumber    String
  status           InvoiceStatus       @default(DRAFT)
  source           InvoiceSource       @default(GENERATED)
  clientId         String?
  projectId        String?
  templateType     InvoiceTemplateType @default(CLASSIC)
  customTemplateId String?
  fileUrl          String?

  senderName       String?
  senderAddress    String?
  senderSiret      String?
  senderEmail      String?
  senderPhone      String?
  senderLogoUrl    String?
  senderPostalCode String?
  senderCity       String?
  senderCountry    String?
  senderVatMention String?

  clientName       String?
  clientEmail      String?
  clientAddress    String?
  clientPostalCode String?
  clientCity       String?
  clientCountry    String?

  location         String?
  title            String?
  subject          String?
  bankName         String?
  iban             String?
  bic              String?
  paymentTerms     String?
  issueDate        DateTime            @default(now())
  dueDate          DateTime?
  notes            String?

  subtotal         Float               @default(0)
  taxRate          Float?              @default(0)
  taxAmount        Float               @default(0)
  total            Float               @default(0)

  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  client           Client?             @relation(fields: [clientId], references: [id], onDelete: SetNull)
  project          Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  customTemplate   InvoiceTemplate?    @relation(fields: [customTemplateId], references: [id], onDelete: SetNull)
  items            InvoiceItem[]

  @@unique([userId, number])
  @@index([userId, status])
  @@index([userId, issueDate])
  @@index([clientId])
  @@index([projectId])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  category    String?
  description String
  quantity    Float    @default(1)
  unitPrice   Float    @default(0)
  amount      Float    @default(0)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, sortOrder])
}

model InvoiceTemplate {
  id        String              @id @default(cuid())
  userId    String
  name      String
  type      InvoiceTemplateType @default(CUSTOM)
  fileUrl   String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices  Invoice[]

  @@unique([userId, name])
  @@index([userId])
}

enum ExpenseRecurrence {
  MONTHLY
  ANNUAL
  ONE_TIME
}

model Expense {
  id         String             @id @default(cuid())
  userId     String
  name       String
  amount     Float              @default(0)
  recurrence ExpenseRecurrence  @default(MONTHLY)
  category   String?
  notes      String?
  color      String?
  isActive   Boolean            @default(true)
  startDate  DateTime           @default(now())
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices   ExpenseReceipt[]

  @@index([userId])
  @@index([userId, isActive])
}

model ExpenseReceipt {
  id        String   @id @default(cuid())
  expenseId String
  invoiceNumber String?
  amount    Float?
  billedAt  DateTime @default(now())
  notes     String?
  fileUrl   String
  fileName  String?
  createdAt DateTime @default(now())

  expense   Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@index([expenseId])
  @@index([expenseId, billedAt])
}

model BankAccount {
  id        String   @id @default(cuid())
  userId    String
  label     String
  bankName  String?
  iban      String
  bic       String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AccessCode {
  id        String   @id @default(cuid())
  code      String   @unique
  plan      UserPlan
  maxUses   Int?
  usedCount Int      @default(0)
  expiresAt DateTime?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  redemptions AccessCodeRedemption[]
}

model AccessCodeRedemption {
  id           String     @id @default(cuid())
  accessCodeId String
  userId       String
  previousPlan UserPlan
  newPlan      UserPlan
  redeemedAt   DateTime   @default(now())
  accessCode   AccessCode @relation(fields: [accessCodeId], references: [id], onDelete: Cascade)

  @@unique([accessCodeId, userId])
  @@index([userId])
}
